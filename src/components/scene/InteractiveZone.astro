---
const { zone } = Astro.props;

const style = `
  --layer-left: ${zone.position.left}%;
  --layer-top: ${zone.position.top}%;
  --layer-width: ${zone.position.width}%;
  --layer-height: ${zone.position.height}%;
  --layer-z: ${zone.zIndex + 1};
`;

const isNavigation = zone.interaction.type === 'navigate';
---
{isNavigation ? (
  <a 
    href={zone.interaction.target}
    class="scene__zone scene__zone--navigate"
    data-zone-type={zone.interaction.type}
    style={style}
    data-parallax-speed={zone.parallaxSpeed}
  >
    {zone.interaction.hoverImage && (
      <img 
        src={zone.interaction.hoverImage} 
        class="scene__zone-hover" 
        alt={`Go to ${zone.interaction.target}`} 
      />
    )}
  </a>
) : (
  <button 
    class="scene__zone scene__zone--state"
    data-zone-type={zone.interaction.type}
    style={style}
    data-parallax-speed={zone.parallaxSpeed}
  >
    {/* State toggling logic via JS */}
  </button>
)}
