---
import { getCollection, render } from "astro:content";
import GameLayout from "../../layouts/GameLayout.astro";
import { pageFade } from "../../transitions";

export async function getStaticPaths() {
	const stories = await getCollection("stories");
	return stories.map((story) => ({
		params: {slug: story.id},
		props: {story},
	}));
}

const {story} = Astro.props;
const {Content} = await render(story);
---

<GameLayout title={`Anemoia - ${story.data.title}`}>
	<main class='story-container' data-scroll-container transition:animate={pageFade}>
		<a href={`/neighborhood/${story.data.neighborhood}`} class='back-btn' data-scroll-fixed>Retour au quartier</a>

		{story.data.audioSrc && <audio src={story.data.audioSrc} autoplay loop transition:persist={`audio-${story.id}`} id='global-audio' />}

		<div class='story-content' data-scroll-section>
			<div class='story-header' data-scroll data-scroll-speed='-0.2'>
				<h1>{story.data.title}</h1>
			</div>

			<div class='story-text' data-scroll data-scroll-speed='-0.2'>
				<Content />
			</div>
		</div>
	</main>
</GameLayout>

<script>
	import LocomotiveScroll from "locomotive-scroll";
	import gsap from "gsap";
	import {ScrollTrigger} from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	document.addEventListener("astro:page-load", () => {
		const container = document.querySelector("[data-scroll-container]");
		if (!container) return;

		const scroll = new LocomotiveScroll({
			lenisOptions: {lerp: 0.08, smoothWheel: true},
		});

		// Optional: Sync ScrollTrigger with Lenis

		scroll.on("scroll", ScrollTrigger.update);
		ScrollTrigger.scrollerProxy(container, {
			scrollTop(value) {
				return arguments.length ? scroll.scrollTo(value, {duration: 0, disableLerp: true}) : scroll.scroll.instance.scroll.y;
			},
			getBoundingClientRect() {
				return {top: 0, left: 0, width: window.innerWidth, height: window.innerHeight};
			},
		});
	});
</script>

<style lang='scss'>
	.story-container {
		background: #111;
		color: #eee;
		min-height: 100vh;
	}

	.back-btn {
		position: fixed;
		top: 2rem;
		left: 2rem;
		z-index: 100;
		color: #fff;
		text-decoration: none;
	}

	.story-content {
		max-width: 800px;
		margin: 0 auto;
	}

	.story-header {
		margin-bottom: 30vh;
		height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		h1 {
			font-size: 6rem;
			text-align: center;
		}
	}

	.story-text {
		font-size: 3rem;
		line-height: 2;

		:global(p) {
			margin-bottom: 10vh;
			opacity: 0.8;
			transition: opacity 0.5s;

			&:hover {
				opacity: 1;
			}
		}
	}
</style>
