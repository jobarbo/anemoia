---
import Foreground from "../components/Foreground.astro";
import Background from "../components/Background.astro";
---

<div class='scene'>
	<Foreground />
	<Background />
</div>

<script>
	(function initMouseParallax() {
		const scene = document.querySelector(".scene");
		if (!scene) return;

		const bg = scene.querySelector('[data-parallax="background"]') as HTMLElement | null;
		const fg = scene.querySelector('[data-parallax="foreground"]') as HTMLElement | null;
		if (!bg || !fg) return;

		if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

		const BG_FACTOR = 15;
		const FG_FACTOR = 40;

		let mouseX = 0;
		let mouseY = 0;
		let rafId: number | null = null;

		function normalize(value: number, size: number): number {
			return (value / size - 0.5) * 2;
		}

		function applyTransforms() {
			const x = Math.max(-1, Math.min(1, mouseX));
			const y = Math.max(-1, Math.min(1, mouseY));
			bg!.style.transform = `translate(${x * BG_FACTOR}px, ${y * BG_FACTOR}px)`;
			fg!.style.transform = `translate(${x * FG_FACTOR}px, ${y * FG_FACTOR}px)`;
			rafId = null;
		}

		function onMouseMove(e: Event) {
			const ev = e as MouseEvent;
			mouseX = normalize(ev.clientX, window.innerWidth);
			mouseY = normalize(ev.clientY, window.innerHeight);
			if (rafId === null) {
				rafId = requestAnimationFrame(applyTransforms);
			}
		}

		window.addEventListener("mousemove", onMouseMove);
	})();
</script>

<style>
	.scene {
		position: relative;
		width: 100%;
		height: 100%;
		background-color: rgb(195, 239, 255);
	}
</style>
