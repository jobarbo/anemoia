---
import {getCollection} from "astro:content";
import GameLayout from "../../layouts/GameLayout.astro";
import SceneRenderer from "../../components/scene/SceneRenderer.astro";
import SketchCanvas from "../../components/effects/SketchCanvas.astro";
import {pageSlideFromBottom} from "../../transitions";

import bgImage from "../../assets/background.png";
import fgImage from "../../assets/foreground.png";

export async function getStaticPaths() {
	const neighborhoods = await getCollection("neighborhoods");
	return neighborhoods.map((n) => ({
		params: {slug: n.data.slug},
		props: {neighborhood: n.data},
	}));
}

const {neighborhood} = Astro.props;

// In a real scenario, we'd load the JSON file from neighborhood.scenePath.
// Since we don't have the real PSD exported, we mock a simple manifest.
const mockManifest = {
	canvas: {width: 1920, height: 1080},
	layers: [
		{
			name: "background",
			file: bgImage.src, // using imported asset
			zIndex: 0,
			position: {left: 0, top: 0, width: 110, height: 110},
			parallaxSpeed: 0.05,
			interactive: false,
		},
		{
			name: "foreground",
			file: fgImage.src,
			zIndex: 1,
			position: {left: 0, top: 0, width: 110, height: 110},
			parallaxSpeed: 0.15,
			interactive: true,
			interaction: {
				type: "navigate",
				target: `/story/${neighborhood.stories[0] || "la-memoire"}`,
				hoverImage: null,
			},
		},
	],
};
---

<GameLayout title={`Anemoia - ${neighborhood.name}`}>
	{neighborhood.audioSrc && (
		<audio id="global-audio" src={neighborhood.audioSrc} loop transition:persist={`neighborhood-audio-${neighborhood.slug}`} />
	)}
	<main class='neighborhood-container' transition:name={`neighborhood-${neighborhood.slug}`} transition:animate={pageSlideFromBottom}>
		<a href='/overworld' class='back-btn'>Retour à la carte</a>

		<!-- Real scene renderer would use the actual manifest -->
		<SceneRenderer manifest={mockManifest} sceneSlug='mock' class='neighborhood-scene' viewportAspectRatio>
			<SketchCanvas slot="background" sketch="snow" />
		</SceneRenderer>
	</main>
</GameLayout>

<script>
	import {initMouseParallax} from "../../scripts/parallax";

	document.addEventListener("astro:page-load", () => {
		const layers = document.querySelectorAll(".neighborhood-scene .layer, .neighborhood-scene .zone");
		if (layers.length > 0) {
			initMouseParallax(layers);
		}
	});
</script>

<style lang='scss'>
	.neighborhood-container {
		height: 100vh;
		background: #000;
		overflow: hidden;
		position: relative;
	}

	.back-btn {
		position: absolute;
		top: 2rem;
		left: 2rem;
		z-index: 100;
		color: #fff;
		text-decoration: none;
		background: rgba(0, 0, 0, 0.5);
		padding: 0.5rem 1rem;
		border-radius: 4px;
	}

	.neighborhood-scene {
		width: 100%;
		height: 100%;
	}
</style>
