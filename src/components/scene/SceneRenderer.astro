---
import SceneLayer from "./SceneLayer.astro";
import InteractiveZone from "./InteractiveZone.astro";

const {manifest, class: className, sceneSlug, viewportAspectRatio = false} = Astro.props;
---

<div class={`scene ${className ?? ""}`} data-scene-renderer style={viewportAspectRatio ? undefined : `aspect-ratio: ${manifest.canvas.width} / ${manifest.canvas.height}`}>
	{
		manifest.layers.map((layer) => (
			<div class='scene__layer-container'>
				<SceneLayer layer={layer} scenePath={`/assets/scenes/${sceneSlug}/layers`} />

				{layer.interactive && layer.interaction && <InteractiveZone zone={layer} />}
				<div class='scene__layer-slot-outlet' data-slot-outlet={layer.name}></div>
			</div>
		))
	}
	<div class='scene__slotted' data-scene-slotted>
		<slot />
	</div>
</div>

<style lang='scss'>
	@use "../../styles/mixins" as *;

	/* Block: scene (réservé à SceneRenderer) */
	.scene {
		position: relative;
		width: 100%;
		max-width: 100vw;
		overflow: hidden;

		&.neighborhood-scene {
			aspect-ratio: unset;
			width: 100%;
			height: 100%;
		}
	}

	.scene__layer-container {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.scene__layer-slot-outlet {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.scene__slotted {
		position: absolute;
		width: 0;
		height: 0;
		overflow: hidden;
	}

	/* Layout des blocs enfants (layer, zone) — positionnement par le parent */

	.scene .zone {
		position: absolute;
		left: var(--layer-left);
		top: var(--layer-top);
		width: var(--layer-width);
		height: var(--layer-height);
		z-index: var(--layer-z);
		display: block;
		cursor: pointer;

		&--navigate .zone__hover {
			opacity: 0;
			transition: opacity 0.3s ease;
			@include absolute-fill;
			object-fit: cover;
		}

		&--navigate:hover .zone__hover {
			opacity: 1;
		}
	}
</style>

<script>
	import {initMouseParallax} from "../../scripts/parallax.js";

	/**
	 * Move slotted content into the layer outlet that matches its data-slot.
	 * Layer names come from the manifest (e.g. Photoshop JSON).
	 */
	function distributeSlottedContent(scene: Element) {
		const outlet = scene.querySelector("[data-scene-slotted]");
		if (!outlet) return;
		const layerName = (el: Element) => el.getAttribute("data-slot") ?? el.getAttribute("slot");
		Array.from(outlet.children).forEach((child) => {
			const targetName = layerName(child);
			if (!targetName) return;
			const target = scene.querySelector(`[data-slot-outlet="${targetName}"]`);
			if (target) target.appendChild(child);
		});
	}

	document.addEventListener("astro:page-load", () => {
		document.querySelectorAll("[data-scene-renderer]").forEach((scene) => {
			distributeSlottedContent(scene);
			const layers = scene.querySelectorAll(".layer, .zone");
			if (layers.length > 0) {
				initMouseParallax(layers as NodeListOf<Element>);
			}
		});
	});
</script>
