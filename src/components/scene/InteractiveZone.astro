---
const {zone} = Astro.props;

const style = `
  --layer-left: ${zone.position.left}%;
  --layer-top: ${zone.position.top}%;
  --layer-width: ${zone.position.width}%;
  --layer-height: ${zone.position.height}%;
  --layer-z: ${zone.zIndex + 1};
`;

const isNavigation = zone.interaction.type === "navigate";
---

{
	isNavigation ? (
		<a href={zone.interaction.target} class='zone zone--navigate' data-zone-type={zone.interaction.type} style={style} data-parallax-speed={zone.parallaxSpeed}>
			{zone.interaction.hoverImage && <img src={zone.interaction.hoverImage} class='zone__hover' alt={`Go to ${zone.interaction.target}`} />}
		</a>
	) : (
		<button class='zone zone--state' data-zone-type={zone.interaction.type} style={style} data-parallax-speed={zone.parallaxSpeed}>
			{/* State toggling logic via JS */}
		</button>
	)
}

<style lang='scss'>
	.zone {
		position: absolute;
		left: var(--layer-left);
		top: var(--layer-top);
		width: var(--layer-width);
		height: var(--layer-height);
		z-index: var(--layer-z);
		display: block;
		cursor: pointer;

		&--navigate {
			.zone__hover {
				opacity: 0;
				transition: opacity 0.3s ease;
				@include absolute-fill;
				object-fit: cover;
			}

			&:hover .zone__hover {
				opacity: 1;
			}
		}
	}
</style>
