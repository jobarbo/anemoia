---
/**
 * Shell SPA partagé — données embarquées + overlay + router.
 * Utilisé par index, les routes dynamiques et la page 404.
 */
import GameLayout from "../layouts/GameLayout.astro";
import {getCollection} from "astro:content";

const neighborhoods = await getCollection("neighborhoods");
const storiesCollection = await getCollection("stories");

function parseMarkdownBlocks(md) {
	const blocks = [];
	const lines = md.replace(/\r\n/g, "\n").split("\n");
	let paraLines = [];

	const flushPara = () => {
		const text = paraLines.join(" ").trim();
		if (text) blocks.push({type: "p", text});
		paraLines = [];
	};

	for (const raw of lines) {
		const line = raw.trim();
		if (!line || /^---+$/.test(line)) {
			flushPara();
			continue;
		}

		const h1 = line.match(/^#\s+(.+)/);
		if (h1) {
			flushPara();
			blocks.push({type: "h1", text: h1[1].trim()});
			continue;
		}

		const h2 = line.match(/^#{2,3}\s+(.+)/);
		if (h2) {
			flushPara();
			blocks.push({type: "h2", text: h2[1].trim()});
			continue;
		}

		// Table row: | cell | cell |
		if (/^\|/.test(line) && /\|$/.test(line)) {
			flushPara();
			// Separator row — skip
			if (/^\|[-| :]+\|$/.test(line)) continue;
			const cells = line.split("|").slice(1, -1).map((c) =>
				c.trim()
				 .replace(/!\[.*?\]\(.*?\)/g, "")
				 .replace(/\[(.+?)\]\(.*?\)/g, "$1")
				 .replace(/`([^`]+)`/g, "$1")
				 .replace(/\*\*(.+?)\*\*/g, "$1")
				 .replace(/\*(.+?)\*/g, "$1")
				 .replace(/_(.+?)_/g, "$1")
			);
			const last = blocks[blocks.length - 1];
			if (last?.type === "table") {
				last.rows.push(cells);
			} else {
				// First row becomes headers
				blocks.push({type: "table", headers: cells, rows: []});
			}
			continue;
		}

		const listItem = line.match(/^[-*+]\s+(.+)/) ?? line.match(/^\d+\.\s+(.+)/);
		if (listItem) {
			flushPara();
			const cleanedLi = listItem[1]
				.replace(/!\[.*?\]\(.*?\)/g, "")
				.replace(/\[(.+?)\]\(.*?\)/g, "$1")
				.replace(/`([^`]+)`/g, "$1")
				.replace(/\*\*(.+?)\*\*/g, "$1")
				.replace(/\*(.+?)\*/g, "$1")
				.replace(/_(.+?)_/g, "$1");
			if (cleanedLi.trim()) blocks.push({type: "li", text: cleanedLi.trim()});
			continue;
		}

		const cleaned = line
			.replace(/!\[.*?\]\(.*?\)/g, "")
			.replace(/\[(.+?)\]\(.*?\)/g, "$1")
			.replace(/`([^`]+)`/g, "$1")
			.replace(/\*\*(.+?)\*\*/g, "$1")
			.replace(/\*(.+?)\*/g, "$1")
			.replace(/_(.+?)_/g, "$1");

		if (cleaned.trim()) paraLines.push(cleaned.trim());
		else flushPara();
	}
	flushPara();
	return blocks;
}

const storiesMap = Object.fromEntries(
	storiesCollection.map((story) => [
		story.id,
		{
			id: story.id,
			title: story.data.title,
			neighborhood: story.data.neighborhood,
			returnTo: story.data.returnTo ?? "neighborhood",
			audioSrc: story.data.audioSrc ?? null,
			order: story.data.order,
			blocks: parseMarkdownBlocks(story.body),
		},
	])
);

const gameData = {
	neighborhoods: neighborhoods.map((n) => n.data),
	stories: storiesMap,
};
---

<GameLayout title="Anemoia">
	<main id='game-container' data-game-screen='splash'></main>
	<script type='application/json' id='game-data' set:html={JSON.stringify(gameData)}></script>
</GameLayout>

<script>
	import {GlobalShaderOverlay} from "../lib/shaders/global-shader-overlay.js";
	import {SceneRouter} from "../lib/router/scene-router.js";

	const container = document.getElementById("game-container") as HTMLElement;

	const overlay = new GlobalShaderOverlay();
	overlay.mount(container);

	const router = new SceneRouter({container, overlay});
	router.bootFromUrl();
</script>

<style lang='scss'>
	#game-container {
		width: 100vw;
		height: 100vh;
		overflow: hidden;
		position: relative;
		background: #000;
	}
</style>
