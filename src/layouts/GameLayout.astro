---
import "../styles/global.scss";
import {THEME_FONT} from "../lib/utils/retro-theme.js";

const {title = "Anemoia", audioSrc, htmlLang = "fr"} = Astro.props;
const audioAttrs = typeof audioSrc === "string" && audioSrc.length > 0 ? {src: audioSrc} : {};
const googleFontCssUrl = THEME_FONT.provider === "google" ? THEME_FONT.googleCssUrl : "";
---

<html lang={htmlLang}>
	<head>
		<meta charset='utf-8' />
		<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
		<meta name='viewport' content='width=device-width, initial-scale=1' />
		{
			googleFontCssUrl && (
				<>
					<link rel='preconnect' href='https://fonts.googleapis.com' />
					<link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
					<link rel='stylesheet' href={googleFontCssUrl} />
				</>
			)
		}
		<title>{title}</title>
	</head>
	<body>
		<canvas
			id='ht-debug'
			data-html2canvas-ignore='true'
			style='display:none;position:fixed;top:1rem;right:1rem;z-index:9999;border:2px solid #ff9b52;border-radius:4px;box-shadow:0 0 12px rgba(255,155,82,.45)'></canvas>
		<script is:inline>
			(function () {
				const canvas = document.getElementById("ht-debug");
				const ctx = canvas.getContext("2d");
				window.__htDebug = function (video, x, y) {
					canvas.style.display = "block";
					const vw = video.videoWidth || 640;
					const vh = video.videoHeight || 480;
					const w = 200;
					const h = Math.round((w * vh) / vw);
					if (canvas.width !== w || canvas.height !== h) {
						canvas.width = w;
						canvas.height = h;
					}
					ctx.drawImage(video, 0, 0, w, h);
					const dx = ((x + 1) / 2) * w;
					const dy = ((y + 1) / 2) * h;
					ctx.strokeStyle = "rgba(255,155,82,0.45)";
					ctx.lineWidth = 1;
					ctx.beginPath();
					ctx.moveTo(dx, 0);
					ctx.lineTo(dx, h);
					ctx.moveTo(0, dy);
					ctx.lineTo(w, dy);
					ctx.stroke();
					ctx.fillStyle = "#ffb86c";
					ctx.beginPath();
					ctx.arc(dx, dy, 5, 0, Math.PI * 2);
					ctx.fill();
				};
			})();
		</script>
		<slot />
		<audio id='global-audio' loop transition:persist='global-audio' {...audioAttrs}></audio>
		<!-- GlobalShaderOverlay is bootstrapped in index.astro (SPA mode) -->
	</body>
</html>
