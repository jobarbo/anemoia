---
import GameLayout from "../layouts/GameLayout.astro";
import {pageFade} from "../lib/transitions";

// Fichier audio de la scène splash (dans public/). Mettre à null pour désactiver.
const audioSrc = "/assets/scenes/splash/ambient.mp3";
---

<GameLayout title="Anemoia - Start" audioSrc={audioSrc}>
	<main class='splash-container' transition:animate={pageFade}>
		<div class='splash-content'>
			<h1>Anémoia</h1>
			<p>Un projet d'art par Olivier Laforest et Jonathan Barbeau</p>
			<a href='/overworld' class='start-btn'>Commencer</a>
		</div>
	</main>
</GameLayout>

<style lang='scss'>
	.splash-container {
		@include flex-center;
		height: 100vh;
		background-color: $color-bg;
	}

	.splash-content {
		text-align: center;
	}

	h1 {
		font-size: 4rem;
		color: $color-accent;
	}

	.start-btn {
		display: inline-block;
		margin-top: 2rem;
		padding: 1rem 2rem;
		background: #fff;
		color: #000;
		text-decoration: none;
		border-radius: 4px;
		font-weight: bold;
		transition: transform 0.2s;

		&:hover {
			transform: scale(1.05);
		}
	}
</style>
