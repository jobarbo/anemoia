---
import GameLayout from "../layouts/GameLayout.astro";
import BackButton from "../components/ui/BackButton.astro";
import {getCollection} from "astro:content";
import {pageFade} from "../lib/transitions.js";

const neighborhoods = await getCollection("neighborhoods");

console.log("neighborhoods", neighborhoods);

// Fichier audio de la carte (dans public/). Mettre à null pour désactiver.
const audioSrc = "/assets/scenes/overworld/ambient.mp3";
---

<GameLayout title='Anemoia - Overworld' audioSrc={audioSrc}>
	<main class='overworld-container' transition:animate={pageFade}>
		<h1>Carte de la ville</h1>

		<div class='map-wrapper'>
			{
				neighborhoods.map((location) => (
					<a href={`/neighborhood/${location.data.slug}`} class='hood-pin' style={`left: ${location.data.position.x}%; top: ${location.data.position.y}%`}>
						<span class='hood-name'>{location.data.name}</span>
					</a>
				))
			}
		</div>

		<BackButton href='/' label='Retour au menu' />
	</main>
</GameLayout>

<style lang='scss'>
	@use "../styles/component/overworld-page";
</style>
