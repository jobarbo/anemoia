---
import {ClientRouter} from "astro:transitions";
import "../styles/global.scss";
import AudioPlayer from "../components/ui/AudioPlayer.astro";

const {title = "Anemoia", audioSrc} = Astro.props;
---

<html lang='fr'>
	<head>
		<meta charset='utf-8' />
		<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
		<meta name='viewport' content='width=device-width, initial-scale=1' />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body>
		<canvas id='ht-debug' data-html2canvas-ignore='true' style='display:none;position:fixed;top:1rem;right:1rem;z-index:9999;border:2px solid #0f0;border-radius:4px;box-shadow:0 0 12px rgba(0,255,0,.4)'></canvas>
		<script is:inline>
			(function () {
				const canvas = document.getElementById("ht-debug");
				const ctx = canvas.getContext("2d");
				window.__htDebug = function (video, x, y) {
					canvas.style.display = "block";
					const vw = video.videoWidth || 640;
					const vh = video.videoHeight || 480;
					const w = 200;
					const h = Math.round((w * vh) / vw);
					if (canvas.width !== w || canvas.height !== h) {
						canvas.width = w;
						canvas.height = h;
					}
					ctx.drawImage(video, 0, 0, w, h);
					const dx = ((x + 1) / 2) * w;
					const dy = ((y + 1) / 2) * h;
					ctx.strokeStyle = "rgba(0,255,0,0.4)";
					ctx.lineWidth = 1;
					ctx.beginPath();
					ctx.moveTo(dx, 0);
					ctx.lineTo(dx, h);
					ctx.moveTo(0, dy);
					ctx.lineTo(w, dy);
					ctx.stroke();
					ctx.fillStyle = "#0f0";
					ctx.beginPath();
					ctx.arc(dx, dy, 5, 0, Math.PI * 2);
					ctx.fill();
				};
			})();
		</script>
		<slot />
		{
			audioSrc && (
				<>
					<audio id='global-audio' src={audioSrc} loop transition:persist={audioSrc} />
					<div data-html2canvas-ignore='true'>
						<AudioPlayer />
					</div>
				</>
			)
		}
		<script>
			import {GlobalShaderOverlay} from "../lib/global-shader-overlay.js";

			let overlay: InstanceType<typeof GlobalShaderOverlay> | null = null;

			document.addEventListener("astro:page-load", () => {
				const container = document.querySelector<HTMLElement>(".neighborhood-container");
				if (container && !overlay) {
					overlay = new GlobalShaderOverlay();
					overlay.mount(container);
				} else if (!container && overlay) {
					overlay.destroy();
					overlay = null;
				}
			});

			document.addEventListener("astro:before-preparation", () => {
				overlay?.destroy();
				overlay = null;
			});
		</script>
	</body>
</html>
