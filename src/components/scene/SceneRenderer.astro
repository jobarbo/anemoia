---
import SceneLayer from "./SceneLayer.astro";
import InteractiveZone from "./InteractiveZone.astro";

interface Layer {
	name: string;
	file: string;
	zIndex: number;
	position: {left: number; top: number; width: number; height: number};
	parallaxSpeed: number;
	interactive: boolean;
	interaction?: {
		type: string;
		target?: string;
		hoverImage?: string | null;
	};
	type?: string;
}

const {manifest, class: className, sceneSlug, viewportAspectRatio = false} = Astro.props;
---

<div class={`scene ${className ?? ""}`} style={viewportAspectRatio ? undefined : `aspect-ratio: ${manifest.canvas.width} / ${manifest.canvas.height}`}>
	{
		manifest.layers.map((layer: Layer) => (
			<div class='scene__layer-container'>
				<SceneLayer layer={layer} scenePath={`/assets/scenes/${sceneSlug}/layers`} />

				{layer.interactive && layer.interaction && <InteractiveZone zone={layer} />}
				{layer.name === "background" && <slot name="background" />}
				{layer.name === "foreground" && <slot name="foreground" />}
			</div>
		))
	}
	<slot />
</div>

<style lang="scss">
	@use "../../styles/mixins" as *;

	/* Block: scene (réservé à SceneRenderer) */
	.scene {
		position: relative;
		width: 100%;
		max-width: 100vw;
		overflow: hidden;

		&.neighborhood-scene {
			aspect-ratio: unset;
			width: 100%;
			height: 100%;
		}
	}

	.scene__layer-container {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	/* Layout des blocs enfants (layer, zone) — positionnement par le parent */
	.scene .layer {
		position: absolute;
		left: var(--layer-left);
		top: var(--layer-top);
		width: var(--layer-width);
		height: var(--layer-height);
		z-index: var(--layer-z);
		will-change: transform;
		object-fit: cover;
	}

	.scene .zone {
		position: absolute;
		left: var(--layer-left);
		top: var(--layer-top);
		width: var(--layer-width);
		height: var(--layer-height);
		z-index: var(--layer-z);
		display: block;
		cursor: pointer;

		&--navigate .zone__hover {
			opacity: 0;
			transition: opacity 0.3s ease;
			@include absolute-fill;
			object-fit: cover;
		}

		&--navigate:hover .zone__hover {
			opacity: 1;
		}
	}
</style>
