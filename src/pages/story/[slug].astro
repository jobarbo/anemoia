---
import {getCollection, render} from "astro:content";
import GameLayout from "../../layouts/GameLayout.astro";
import BackButton from "../../components/ui/BackButton.astro";
import {pageFade} from "../../lib/transitions.js";

export async function getStaticPaths() {
	const stories = await getCollection("stories");
	return stories.map((story) => ({
		params: {slug: story.id},
		props: {story},
	}));
}

const {story} = Astro.props;
const {Content} = await render(story);

console.log("story", story);
---

<GameLayout title={`Anemoia - ${story.data.title}`} audioSrc={story.data.audioSrc}>
	<main class='story-container' data-game-screen='story' data-scroll-container transition:animate={pageFade}>
		<BackButton href={`/neighborhood/${story.data.neighborhood}`} label='Retour au quartier' dataScrollFixed />

		<div class='story-content' data-scroll-section>
			<div class='story-header' data-scroll data-scroll-speed='-0.2'>
				<h1>{story.data.title}</h1>
			</div>

			<div class='story-text' data-scroll data-scroll-speed='-0.2'>
				<Content />
			</div>
		</div>
	</main>
</GameLayout>

<script>
	import LocomotiveScroll from "locomotive-scroll";
	import gsap from "gsap";
	import {ScrollTrigger} from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	document.addEventListener("astro:page-load", () => {
		const container = document.querySelector("[data-scroll-container]");
		if (!container) return;

		const scroll = new LocomotiveScroll({
			lenisOptions: {lerp: 0.08, smoothWheel: true},
			scrollCallback: () => ScrollTrigger.update(),
		});

		ScrollTrigger.scrollerProxy(container, {
			scrollTop(value) {
				if (arguments.length && value !== undefined) {
					scroll.scrollTo(value, {immediate: true});
					return;
				}
				return scroll.lenisInstance?.scroll ?? 0;
			},
			getBoundingClientRect() {
				return {top: 0, left: 0, width: window.innerWidth, height: window.innerHeight};
			},
		});
	});
</script>

<style lang='scss'>
	@use "../../styles/component/story-page";
</style>
