---
import "../styles/global.scss";
import AudioPlayer from "../components/ui/AudioPlayer.astro";

const {title = "Anemoia", audioSrc} = Astro.props;
const audioAttrs = typeof audioSrc === "string" && audioSrc.length > 0 ? {src: audioSrc} : {};
---

<html lang='fr'>
	<head>
		<meta charset='utf-8' />
		<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
		<meta name='viewport' content='width=device-width, initial-scale=1' />
		<title>{title}</title>
	</head>
	<body>
		<canvas
			id='ht-debug'
			data-html2canvas-ignore='true'
			style='display:none;position:fixed;top:1rem;right:1rem;z-index:9999;border:2px solid #0f0;border-radius:4px;box-shadow:0 0 12px rgba(0,255,0,.4)'></canvas>
		<script is:inline>
			(function () {
				const canvas = document.getElementById("ht-debug");
				const ctx = canvas.getContext("2d");
				window.__htDebug = function (video, x, y) {
					canvas.style.display = "block";
					const vw = video.videoWidth || 640;
					const vh = video.videoHeight || 480;
					const w = 200;
					const h = Math.round((w * vh) / vw);
					if (canvas.width !== w || canvas.height !== h) {
						canvas.width = w;
						canvas.height = h;
					}
					ctx.drawImage(video, 0, 0, w, h);
					const dx = ((x + 1) / 2) * w;
					const dy = ((y + 1) / 2) * h;
					ctx.strokeStyle = "rgba(0,255,0,0.4)";
					ctx.lineWidth = 1;
					ctx.beginPath();
					ctx.moveTo(dx, 0);
					ctx.lineTo(dx, h);
					ctx.moveTo(0, dy);
					ctx.lineTo(w, dy);
					ctx.stroke();
					ctx.fillStyle = "#0f0";
					ctx.beginPath();
					ctx.arc(dx, dy, 5, 0, Math.PI * 2);
					ctx.fill();
				};
			})();
		</script>
		<slot />
		<audio id='global-audio' loop transition:persist='global-audio' {...audioAttrs} />
		<div data-html2canvas-ignore='true'>
			<AudioPlayer />
		</div>
		<!-- GlobalShaderOverlay is bootstrapped in index.astro (SPA mode) -->
	</body>
</html>
