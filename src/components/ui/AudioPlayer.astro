---

---

<div class='audio-player' id='audio-player-container' style='display: none;'>
	<button id='toggle-audio' aria-label='Toggle Audio'>
		<span class='icon-play'>▶</span>
		<span class='icon-pause' style='display:none;'>⏸</span>
	</button>
</div>

<style>
	.audio-player {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		z-index: 1000;
	}

	button {
		background: rgba(255, 255, 255, 0.2);
		border: 1px solid rgba(255, 255, 255, 0.5);
		color: white;
		width: 48px;
		height: 48px;
		border-radius: 50%;
		cursor: pointer;
		backdrop-filter: blur(4px);
		transition: background 0.3s;
	}

	button:hover {
		background: rgba(255, 255, 255, 0.4);
	}
</style>

<script>
	document.addEventListener("astro:page-load", () => {
		const container = document.getElementById("audio-player-container");
		const btn = document.getElementById("toggle-audio");
		const audio = document.getElementById("global-audio");

		if (!btn || !container) return;

		// Hide when no audio element or no valid source (avoids NotSupportedError)
		if (!audio || !audio.src || audio.src === window.location.href) {
			container.style.display = "none";
			return;
		}

		// Hide when media file is not found or fails to load (404, wrong format, etc.)
		const hideBecauseError = () => {
			container.style.display = "none";
		};
		audio.addEventListener("error", hideBecauseError);
		// If already in error state (e.g. 404 before we attached)
		if (audio.error && audio.error.code !== 0) {
			container.style.display = "none";
			return;
		}

		container.style.display = "block";

		const iconPlay = btn.querySelector(".icon-play");
		const iconPause = btn.querySelector(".icon-pause");

		// Initial state check
		if (!audio.paused) {
			iconPlay.style.display = "none";
			iconPause.style.display = "inline";
		}

		btn.addEventListener("click", () => {
			if (audio.paused) {
				audio.play().catch(() => {
					// No supported sources or autoplay blocked — keep UI in play state
				});
				iconPlay.style.display = "none";
				iconPause.style.display = "inline";
			} else {
				audio.pause();
				iconPlay.style.display = "inline";
				iconPause.style.display = "none";
			}
		});
	});
</script>
