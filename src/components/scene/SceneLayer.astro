---
const {layer, scenePath} = Astro.props;
const {parentLayer} = Astro.props;
const {layerDepth = 0.5} = Astro.props;

const clipMaskPath = layer.clipped && parentLayer ? (parentLayer.file.startsWith("/") || parentLayer.file.startsWith("http") ? parentLayer.file : `${scenePath}/${parentLayer.file}`) : null;

const style = `
	--layer-center-left: ${layer.position.centerLeft}%;
	--layer-center-top: ${layer.position.centerTop}%;
	--layer-width: ${layer.position.width}%;
	--layer-height: ${layer.position.height}%;
	--layer-z: ${layer.zIndex};
	--layer-opacity: ${typeof layer.opacity === "number" ? layer.opacity : 1};
	--layer-blend: ${layer.blendMode ?? "normal"};
`;

// Handle both standard file names (appended to scenePath) and absolute/imported paths (starting with /)
const imagePath = layer.file.startsWith("/") || layer.file.startsWith("http") ? layer.file : `${scenePath}/${layer.file}`;

const isClipped = Boolean(layer.clipped && parentLayer);

// Convert center to corner position (for wrapper positioning)
const centerToCornerLeft = (centerLeft: number, width: number) => centerLeft - width / 2;
const centerToCornerTop = (centerTop: number, height: number) => centerTop - height / 2;

const parentLeftCorner = parentLayer ? centerToCornerLeft(parentLayer.position.centerLeft, parentLayer.position.width) : 0;
const parentTopCorner = parentLayer ? centerToCornerTop(parentLayer.position.centerTop, parentLayer.position.height) : 0;

// For clipped layers: calculate relative position of child center within parent
const childRelCenterLeft = isClipped ? ((layer.position.centerLeft - parentLayer.position.centerLeft) / parentLayer.position.width) * 100 : layer.position.centerLeft;
const childRelCenterTop = isClipped ? ((layer.position.centerTop - parentLayer.position.centerTop) / parentLayer.position.height) * 100 : layer.position.centerTop;
const childRelWidth = isClipped ? (layer.position.width / parentLayer.position.width) * 100 : layer.position.width;
const childRelHeight = isClipped ? (layer.position.height / parentLayer.position.height) * 100 : layer.position.height;

const clipWrapperStyle = isClipped
	? `
	position: absolute;
	left: ${parentLeftCorner}%;
	top: ${parentTopCorner}%;
	width: ${parentLayer.position.width}%;
	height: ${parentLayer.position.height}%;
	z-index: ${layer.zIndex};
	overflow: hidden;
	-webkit-mask-image: url(${clipMaskPath});
	mask-image: url(${clipMaskPath});
	-webkit-mask-mode: luminance;
	mask-mode: luminance;
	-webkit-mask-repeat: no-repeat;
	mask-repeat: no-repeat;
	-webkit-mask-size: 100% 100%;
	mask-size: 100% 100%;
	-webkit-mask-position: left top;
	mask-position: left top;
`
	: "";

const childStyle = isClipped
	? `
	position: absolute;
	left: ${childRelCenterLeft}%;
	top: ${childRelCenterTop}%;
	transform: translate(-50%, -50%);
	width: ${childRelWidth}%;
	height: ${childRelHeight}%;
	z-index: ${layer.zIndex};
	opacity: ${typeof layer.opacity === "number" ? layer.opacity : 1};
	mix-blend-mode: ${layer.blendMode ?? "normal"};
`
	: style;
---

{
	isClipped ? (
		<div class='clipped-wrapper' style={clipWrapperStyle} data-parallax-speed={layer.parallaxSpeed} data-parallax-depth={layerDepth}>
			{layer.type === "video" ? (
				<video src={imagePath} autoplay loop muted playsinline class='layer layer--video' style={childStyle} />
			) : (
				<img src={imagePath} alt={layer.name} class='layer layer--image' style={childStyle} />
			)}
		</div>
	) : layer.type === "video" ? (
		<video src={imagePath} autoplay loop muted playsinline class='layer layer--video' style={style} data-parallax-speed={layer.parallaxSpeed} data-parallax-depth={layerDepth} />
	) : (
		<img src={imagePath} alt={layer.name} class='layer layer--image' style={style} data-parallax-speed={layer.parallaxSpeed} data-parallax-depth={layerDepth} />
	)
}

<style lang='scss'>
	/* Block: layer (réservé à SceneLayer) — styles propres au bloc */
	.layer {
		position: absolute;
		left: var(--layer-center-left);
		top: var(--layer-center-top);
		transform: translate(calc(-50% + var(--parallax-x, 0px)), calc(-50% + var(--parallax-y, 0px) + var(--parallax-scroll-y, 0px)));
		width: var(--layer-width);
		height: var(--layer-height);
		z-index: var(--layer-z);
		will-change: transform;
		object-fit: cover;
		opacity: var(--layer-opacity);
		mix-blend-mode: var(--layer-blend);
	}

	.clipped-wrapper {
		position: absolute;
		overflow: hidden;
		transform: translate(var(--parallax-x, 0px), calc(var(--parallax-y, 0px) + var(--parallax-scroll-y, 0px)));
		will-change: transform;
	}
</style>
