---
/**
 * Hébergeurs statiques : page servie pour URLs inconnues.
 * Le router client monte la scène depuis location.pathname.
 */
import GameShell from "../components/GameShell.astro";

const path = Astro.url.pathname;
const locale = path === "/en" || path.startsWith("/en/") ? "en" : "fr";
---

<GameShell locale={locale} />
