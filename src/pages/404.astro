---
import GameLayout from "../layouts/GameLayout.astro";
---

<GameLayout title="Anemoia — Introuvable">
	<main id='game-container' data-game-screen='not-found' data-dom-snapshot>
		<section class='splash-scene splash-scene--not-found'>
			<div class='splash-scene__inner'>
				<p class='splash-scene__eyebrow'>404</p>
				<h1 class='splash-scene__title'>Page introuvable</h1>
				<a class='splash-scene__action' href='/'>Retour a l'accueil</a>
			</div>
		</section>
	</main>
</GameLayout>

<script>
	import {mountDomOverlay} from "../lib/shaders/mount-dom-overlay.js";

	mountDomOverlay("#game-container");
</script>
