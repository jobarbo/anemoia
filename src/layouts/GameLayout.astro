---
import "../styles/global.scss";
import AudioPlayer from "../components/ui/AudioPlayer.astro";

const {title = "Anemoia", audioSrc} = Astro.props;
const audioAttrs = typeof audioSrc === "string" && audioSrc.length > 0 ? {src: audioSrc} : {};
---

<html lang='fr'>
	<head>
		<meta charset='utf-8' />
		<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
		<meta name='viewport' content='width=device-width, initial-scale=1' />
		<title>{title}</title>
	</head>
	<body>
		<canvas
			id='ht-debug'
			data-html2canvas-ignore='true'
			style='display:none;position:fixed;top:1rem;right:1rem;z-index:9999;border:2px solid #0f0;border-radius:4px;box-shadow:0 0 12px rgba(0,255,0,.4)'></canvas>
		<script is:inline>
			(function () {
				const canvas = document.getElementById("ht-debug");
				const ctx = canvas.getContext("2d");
				window.__htDebug = function (video, x, y) {
					canvas.style.display = "block";
					const vw = video.videoWidth || 640;
					const vh = video.videoHeight || 480;
					const w = 200;
					const h = Math.round((w * vh) / vw);
					if (canvas.width !== w || canvas.height !== h) {
						canvas.width = w;
						canvas.height = h;
					}
					ctx.drawImage(video, 0, 0, w, h);
					const dx = ((x + 1) / 2) * w;
					const dy = ((y + 1) / 2) * h;
					ctx.strokeStyle = "rgba(0,255,0,0.4)";
					ctx.lineWidth = 1;
					ctx.beginPath();
					ctx.moveTo(dx, 0);
					ctx.lineTo(dx, h);
					ctx.moveTo(0, dy);
					ctx.lineTo(w, dy);
					ctx.stroke();
					ctx.fillStyle = "#0f0";
					ctx.beginPath();
					ctx.arc(dx, dy, 5, 0, Math.PI * 2);
					ctx.fill();
				};
			})();
		</script>
		<!--
			Screen curtain — full-viewport black overlay that sits above the shader
			canvas (z 9001).  The `is-booting` class triggers the CRT power-on CSS
			animation on every page load, hiding the brief "unshadered DOM" flash.
			The inline script below intercepts link clicks to play a matching
			screen-off animation before navigating.
		-->
		<div id='screen-curtain' class='is-booting'></div>

		<slot />
		<audio id='global-audio' loop transition:persist='global-audio' {...audioAttrs}></audio>
		<div data-html2canvas-ignore='true'>
			<AudioPlayer />
		</div>
		<!-- GlobalShaderOverlay is bootstrapped by each route that needs it. -->

		<script>
			// Screen-curtain exit animation.
			// Intercepts clicks on internal <a> links, fades the curtain to black,
			// then navigates — so the destination page always boots from black.
			(function () {
				const curtain = document.getElementById("screen-curtain");
				if (!curtain) return;

				document.addEventListener(
					"click",
					function (e) {
						const link = (e.target as Element | null)?.closest("a[href]") as HTMLAnchorElement | null;
						if (!link) return;

						const href = link.getAttribute("href");
						if (!href) return;

						// Skip external, hash-only, protocol links, and explicit new-tab links
						if (
							href.startsWith("http") ||
							href.startsWith("//") ||
							href.startsWith("#") ||
							href.startsWith("mailto:") ||
							href.startsWith("tel:") ||
							link.hasAttribute("target") ||
							link.hasAttribute("download")
						)
							return;

						e.preventDefault();

						// Cancel the boot animation (if still running), force full-screen
						// black instantly, then fade it in over 220 ms.
						curtain.style.animation = "none";
						curtain.style.transform = "none";
						curtain.style.transition = "none";
						curtain.style.opacity = "0";

						// Force reflow so the browser records the opacity:0 baseline
						// before we switch on the transition.
						void curtain.offsetHeight;

						curtain.style.transition = "opacity 0.22s ease-in";
						curtain.style.opacity = "1";

						setTimeout(function () {
							window.location.href = href;
						}, 240);
					},
					true,
				);
			})();
		</script>
	</body>
</html>
