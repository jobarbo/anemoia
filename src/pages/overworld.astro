---
import GameLayout from "../layouts/GameLayout.astro";
import SketchCanvas from "../components/effects/SketchCanvas.astro";
import {getCollection} from "astro:content";
import {pageFade} from "../lib/transitions.js";

const neighborhoods = await getCollection("neighborhoods");

// Add public/assets/scenes/overworld/ambient.mp3 when available; null avoids 404 in console.
const audioSrc = null;

const neighborhoodData = neighborhoods.map((n) => ({
	name: n.data.name,
	slug: n.data.slug,
	position: n.data.position,
}));
---

<GameLayout title='Anemoia - Overworld' audioSrc={audioSrc}>
	<main class='overworld-container' data-game-screen='overworld' transition:animate={pageFade}>
		<SketchCanvas sketch='overworld' data={{neighborhoods: neighborhoodData}} />
	</main>
</GameLayout>

<style lang='scss'>
	.overworld-container {
		width: 100vw;
		height: 100vh;
		overflow: hidden;
		position: relative;
	}
</style>
