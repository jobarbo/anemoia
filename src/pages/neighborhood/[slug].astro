---
import {getCollection} from "astro:content";
import GameLayout from "../../layouts/GameLayout.astro";
import BackButton from "../../components/ui/BackButton.astro";
import SceneRenderer from "../../components/scene/SceneRenderer.astro";
import SketchCanvas from "../../components/effects/SketchCanvas.astro";
import {pageSlideFromBottom} from "../../lib/transitions.js";
import {loadManifest} from "../../lib/load-manifest.js";

export async function getStaticPaths() {
	const neighborhoods = await getCollection("neighborhoods");
	return neighborhoods.map((n) => ({
		params: {slug: n.data.slug},
		props: {neighborhood: n.data},
	}));
}

const {neighborhood} = Astro.props;
const manifest = await loadManifest(neighborhood.scenePath, {
	firstStorySlug: neighborhood.stories[0],
});
---

<GameLayout title={`Anemoia - ${neighborhood.name}`} audioSrc={neighborhood.audioSrc}>
	<main class='neighborhood-container' data-game-screen='neighborhood' transition:name={`neighborhood-${neighborhood.slug}`} transition:animate={pageSlideFromBottom}>
		<div data-html2canvas-ignore='true' class='back-button-overlay'>
			<BackButton href='/overworld' label='Retour à la carte' />
		</div>

		<SceneRenderer manifest={manifest} sceneSlug={neighborhood.slug} class='neighborhood-scene' viewportAspectRatio enableHeadTracking>
			<SketchCanvas slotTarget='foreground' sketch='snow' />
		</SceneRenderer>
	</main>
</GameLayout>

<style lang='scss'>
	@use "../../styles/component/neighborhood-page";

	.back-button-overlay {
		position: fixed;
		top: 0;
		left: 0;
		z-index: 900002; // Above the shader overlay (9000) — stays crisp and undistorted
		pointer-events: auto;
	}
</style>
