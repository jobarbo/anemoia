---

---

<div class='audio-player' id='audio-player-container' style='display: none;'>
	<button id='toggle-audio' aria-label='Toggle Audio'>
		<span class='icon-play'>▶</span>
		<span class='icon-pause' style='display:none;'>⏸</span>
	</button>
</div>

<style lang="scss">
	@use "../../styles/component/audio-player";
</style>

<script>
	import {
		refreshGlobalAudioPlayer,
		syncGlobalAudioToggleIcons,
		tryPlayGlobalAudio,
	} from "../../lib/global-audio-ui.js";

	if (!/** @type {Window & {__anemoiaAudioUi?: boolean}} */ (window).__anemoiaAudioUi) {
		window.__anemoiaAudioUi = true;

		document.addEventListener(
			"click",
			(e) => {
				const btn = e.target.closest("#toggle-audio");
				if (!btn) return;
				const audio = /** @type {HTMLAudioElement|null} */ (document.getElementById("global-audio"));
				if (!audio || !audio.src || audio.src === window.location.href) return;
				e.preventDefault();
				if (audio.paused) {
					audio.play().catch(() => {});
				} else {
					audio.pause();
				}
			},
			true
		);

		document.addEventListener(
			"play",
			(e) => {
				if (e.target?.id === "global-audio") syncGlobalAudioToggleIcons(true);
			},
			true
		);
		document.addEventListener(
			"pause",
			(e) => {
				if (e.target?.id === "global-audio") syncGlobalAudioToggleIcons(false);
			},
			true
		);
	}

	document.addEventListener("astro:page-load", () => {
		const audio = /** @type {HTMLAudioElement|null} */ (document.getElementById("global-audio"));
		refreshGlobalAudioPlayer();
		tryPlayGlobalAudio(audio);
	});
</script>
